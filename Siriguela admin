-- COMMAND ENGINE
local cmds={}
local function registerCmd(name,aliases,desc,func)
    cmds[name:lower()]={name=name,aliases=aliases,desc=desc,func=func}
    for _,a in ipairs(aliases) do cmds[a:lower()]=cmds[name:lower()] end
end

local function execCmd(input)
    input=input:match("^%s*(.-)%s*$"); if input=="" then return end
    for alias,real in pairs(Siriguela_Aliases) do
        if input:lower():sub(1,#alias)==alias:lower() then
            input=real..input:sub(#alias+1); break end end
    local parts={}; for p in input:gmatch("%S+") do table.insert(parts,p) end
    local cmdName=(parts[1] or ""):lower(); local args={}
    for i=2,#parts do table.insert(args,parts[i]) end
    table.insert(Siriguela_CmdHistory,input)
    if #Siriguela_CmdHistory>50 then table.remove(Siriguela_CmdHistory,1) end
    Siriguela_HistoryIdx=#Siriguela_CmdHistory+1; addLog("CMD: "..input)
    local cmd=cmds[cmdName]
    if cmd then
        local ok,err=pcall(cmd.func,args)
        if not ok then notify("Error",tostring(err),4); addLog("ERR: "..tostring(err)) end
    else
        notify("Unknown",cmdName.." — type 'cmds' to list",3); addLog("UNKNOWN: "..cmdName)
    end
end

RunBtn.MouseButton1Click:Connect(function() execCmd(CmdBar.Text); CmdBar.Text="" end)

