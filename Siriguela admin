local function makeSliderRow(parent,labelText,order,min,max,default,callback)
    local row=Instance.new("Frame")
    row.BackgroundColor3=C.Secondary; row.BorderSizePixel=0
    row.Size=UDim2.new(1,0,0,50); row.LayoutOrder=order or 0; row.Parent=parent
    local _rc=Instance.new("UICorner"); _rc.CornerRadius=UDim.new(0,6); _rc.Parent=row
    local lbl=Instance.new("TextLabel"); lbl.Parent=row
    lbl.BackgroundTransparency=1; lbl.Position=UDim2.new(0,12,0,5)
    lbl.Size=UDim2.new(1,-60,0,20); lbl.Font=Enum.Font.Gotham
    lbl.Text=labelText; lbl.TextColor3=C.Text; lbl.TextSize=13
    lbl.TextXAlignment=Enum.TextXAlignment.Left
    local valLbl=Instance.new("TextLabel"); valLbl.Parent=row
    valLbl.BackgroundTransparency=1; valLbl.Position=UDim2.new(1,-52,0,5)
    valLbl.Size=UDim2.new(0,46,0,20); valLbl.Font=Enum.Font.GothamBold
    valLbl.Text=tostring(default); valLbl.TextColor3=C.Accent; valLbl.TextSize=13
    valLbl.TextXAlignment=Enum.TextXAlignment.Right
    local track=Instance.new("Frame"); track.Parent=row
    track.BackgroundColor3=C.Border; track.BorderSizePixel=0
    track.Position=UDim2.new(0,12,1,-18); track.Size=UDim2.new(1,-18,0,6)
    local _trc=Instance.new("UICorner"); _trc.CornerRadius=UDim.new(1,0); _trc.Parent=track
    local pct=(default-min)/(max-min)
    local fill=Instance.new("Frame"); fill.Parent=track
    fill.BackgroundColor3=C.Accent; fill.BorderSizePixel=0; fill.Size=UDim2.new(pct,0,1,0)
    local _fc=Instance.new("UICorner"); _fc.CornerRadius=UDim.new(1,0); _fc.Parent=fill
    local handle=Instance.new("TextButton"); handle.Parent=track
    handle.BackgroundColor3=Color3.fromRGB(255,255,255); handle.BorderSizePixel=0
    handle.Size=UDim2.new(0,14,0,14); handle.Position=UDim2.new(pct,-7,0.5,-7); handle.Text=""
    local _hc=Instance.new("UICorner"); _hc.CornerRadius=UDim.new(1,0); _hc.Parent=handle
    themeReg(row,"BackgroundColor3","Secondary"); themeReg(lbl,"TextColor3","Text")
    themeReg(valLbl,"TextColor3","Accent"); themeReg(track,"BackgroundColor3","Border")
    themeReg(fill,"BackgroundColor3","Accent")
    local _sl=false
    local function _sliderMove(inputPos)
        local ta=track.AbsolutePosition; local ts=track.AbsoluteSize
        local rx=math.clamp(inputPos.X-ta.X,0,ts.X); local p=rx/ts.X
        local val=math.floor(min+p*(max-min))
        valLbl.Text=tostring(val); fill.Size=UDim2.new(p,0,1,0)
        handle.Position=UDim2.new(p,-7,0.5,-7); if callback then callback(val) end
    end
    handle.MouseButton1Down:Connect(function() _sl=true end)
    handle.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.Touch then _sl=true end end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            _sl=false end end)
    UserInputService.InputChanged:Connect(function(i)
        if _sl and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            _sliderMove(i.Position)
        end end)
    return row
end

