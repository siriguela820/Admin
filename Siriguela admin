local C = Themes[Siriguela_Theme]

local Siriguela_ThemedElements = {}

local function themeReg(obj, prop, key)
    table.insert(Siriguela_ThemedElements, {obj=obj, prop=prop, key=key})
    obj[prop] = C[key]
end
local function themeRegFunc(fn)
    table.insert(Siriguela_ThemedElements, {func=fn})
    fn()
end

local function applyTheme(theme)
    Siriguela_Theme = theme
    C = Themes[theme] or Themes["cyan"]
    for _, e in ipairs(Siriguela_ThemedElements) do
        if e.func then
            pcall(e.func)
        else
            pcall(function() e.obj[e.prop] = C[e.key] end)
        end
    end
    if Siriguela_ESPEnabled then
        pcall(function() drawESP() end)
    end
    notify("Theme", "Applied: " .. theme)
end

