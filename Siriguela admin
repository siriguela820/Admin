reg("freecam",{"fc2","freecamera","cam"},"Toggle free camera (detached from character)",function()
    if _G.Siriguela_FreecamActive then
        _G.Siriguela_FreecamActive=false
        if _G.Siriguela_FreecamConn then _G.Siriguela_FreecamConn:Disconnect(); _G.Siriguela_FreecamConn=nil end
        Camera.CameraType=Enum.CameraType.Custom; Camera.CameraSubject=getHuman(getChar())
        notify("Freecam","OFF — camera restored"); return end
    _G.Siriguela_FreecamActive=true; Camera.CameraType=Enum.CameraType.Scriptable
    local speed=0.5; local camCF=Camera.CFrame
    local lastMouse=Vector2.new(UserInputService:GetMouseLocation().X,UserInputService:GetMouseLocation().Y)
    local pitch=0; local yaw=0
    local _,_,_,_,_,_,_,_,_,r01,r11,r21=camCF:GetComponents()
    pitch=math.asin(-r21); yaw=math.atan2(r11,r01)-math.pi/2
    notify("Freecam","ON — WASD move, RMB look, Shift=fast, Z=slow")
    _G.Siriguela_FreecamConn=RunService.RenderStepped:Connect(function()
        if not _G.Siriguela_FreecamActive then return end
        local mp=UserInputService:GetMouseLocation(); local dx=mp.X-lastMouse.X; local dy=mp.Y-lastMouse.Y; lastMouse=mp
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            yaw=yaw-dx*0.003; pitch=math.clamp(pitch-dy*0.003,-math.pi/2+0.05,math.pi/2-0.05) end
        local rot=CFrame.Angles(0,yaw,0)*CFrame.Angles(pitch,0,0)
        local spd=UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and speed*4
            or UserInputService:IsKeyDown(Enum.KeyCode.Z) and speed*0.25 or speed
        local move=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move=move+rot.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move=move-rot.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move=move-rot.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move=move+rot.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then move=move+Vector3.yAxis end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then move=move-Vector3.yAxis end
        camCF=CFrame.new(camCF.Position+move*spd)*rot; Camera.CFrame=camCF end)
end)
