local AcBtns={}
local AC_MAX=3
for i=1,AC_MAX do
    local ab=Instance.new("TextButton"); ab.BackgroundTransparency=1
    ab.BorderSizePixel=0; ab.Position=UDim2.new(0,0,0,(i-1)*28)
    ab.Size=UDim2.new(1,0,0,28); ab.Font=Enum.Font.Code
    ab.Text=""; ab.TextColor3=C.Accent; ab.TextSize=13
    ab.TextXAlignment=Enum.TextXAlignment.Left; ab.ZIndex=11; ab.Visible=false; ab.Parent=AutoCompleteFrame
    local _p=Instance.new("UIPadding"); _p.PaddingLeft=UDim.new(0,10); _p.Parent=ab
    themeReg(ab,"TextColor3","Accent"); AcBtns[i]=ab
end

local _AcConns={}
local function updateAutocomplete(text)
    if not Siriguela_AutocompleteOn then AutoCompleteFrame.Visible=false; return end
    local bare=text:sub(#Siriguela_Prefix+1):lower()
    if bare:find("%s") or bare=="" then AutoCompleteFrame.Visible=false; return end
    -- Score matches: prefix match scores highest, name substring next, description match last
    local scored={}; local seen={}
    for k,v in pairs(cmds) do
        if v.name and not seen[v.name] then
            seen[v.name]=true
            local score=0
            local nameL=v.name:lower()
            if nameL:sub(1,#bare)==bare then score=3           -- prefix match on name
            elseif nameL:find(bare,1,true) then score=2        -- substring match on name
            else
                -- check all aliases
                for _,al in ipairs(v.aliases or {}) do
                    local alL=al:lower()
                    if alL:sub(1,#bare)==bare then score=2; break
                    elseif alL:find(bare,1,true) then score=1; break end
                end
                -- check description keywords
                if score==0 and v.desc and v.desc:lower():find(bare,1,true) then score=1 end
            end
            if score>0 then table.insert(scored,{name=v.name,score=score}) end
        end
    end
    -- Sort: higher score first, then alphabetically
    table.sort(scored,function(a,b)
        if a.score~=b.score then return a.score>b.score end
        return a.name<b.name
    end)
    local count=math.min(#scored,AC_MAX)
    -- Disconnect stale connections FIRST to prevent wrong-command bug
    for i=1,AC_MAX do if _AcConns[i] then _AcConns[i]:Disconnect(); _AcConns[i]=nil end end
    for i=1,AC_MAX do
        if i<=count then
            AcBtns[i].Text=Siriguela_Prefix..scored[i].name; AcBtns[i].Visible=true
            local _cap=scored[i].name
            _AcConns[i]=AcBtns[i].MouseButton1Click:Connect(function()
                CmdBar.Text=Siriguela_Prefix.._cap.." "; CmdBar:CaptureFocus()
                CmdBar.CursorPosition=#CmdBar.Text+1; AutoCompleteFrame.Visible=false
            end)
        else AcBtns[i].Text=""; AcBtns[i].Visible=false end
    end
    AutoCompleteFrame.Size=UDim2.new(0,360,0,count*28); AutoCompleteFrame.Visible=(count>0)
end

CmdBar:GetPropertyChangedSignal("Text"):Connect(function() updateAutocomplete(CmdBar.Text) end)
CmdBar.FocusLost:Connect(function()
    task.delay(0.12,function() AutoCompleteFrame.Visible=false end) end)
CmdBar.Focused:Connect(function()
    if CmdBar.Text~="" then updateAutocomplete(CmdBar.Text) end end)

UserInputService.InputBegan:Connect(function(input,gpe)
    if gpe then return end
    if input.KeyCode==Enum.KeyCode.Up and CmdBar:IsFocused() then
        if Siriguela_HistoryIdx>1 then Siriguela_HistoryIdx=Siriguela_HistoryIdx-1
            CmdBar.Text=Siriguela_CmdHistory[Siriguela_HistoryIdx] or "" end
    elseif input.KeyCode==Enum.KeyCode.Down and CmdBar:IsFocused() then
        if Siriguela_HistoryIdx<#Siriguela_CmdHistory then
            Siriguela_HistoryIdx=Siriguela_HistoryIdx+1; CmdBar.Text=Siriguela_CmdHistory[Siriguela_HistoryIdx] or ""
        else Siriguela_HistoryIdx=#Siriguela_CmdHistory+1; CmdBar.Text="" end
    end
    if input.KeyCode==Siriguela_OpenKey then
        MainFrame.Visible=not MainFrame.Visible; Siriguela_Visible=MainFrame.Visible end
end)

