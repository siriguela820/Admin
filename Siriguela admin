local function applyTween(obj, props, t, style, dir)
    style = style or Enum.EasingStyle.Quart
    dir   = dir   or Enum.EasingDirection.Out
    t     = t     or 0.25
    TweenService:Create(obj, TweenInfo.new(t, style, dir), props):Play()
end

local function getRoot(char)
    return char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso"))
end

local function getHuman(char)
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function getChar(plr)
    plr = plr or LP
    return plr and plr.Character
end

local function findPlayer(name)
    name = name:lower()
    if name == "me" then return LP end
    if name == "all" then return Players:GetPlayers() end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #name) == name then return p end
    end
    return nil
end

local function notify(title, msg, duration)
    duration = duration or 4
    task.spawn(function()
        if Siriguela_NotifyFunc then
            Siriguela_NotifyFunc(title, msg, duration)
        end
    end)
end

local function addLog(msg)
    table.insert(Siriguela_Logs, os.date("[%H:%M:%S] ") .. tostring(msg))
    if #Siriguela_Logs > 200 then table.remove(Siriguela_Logs, 1) end
    if Siriguela_LogLabel then
        Siriguela_LogLabel.Text = table.concat(Siriguela_Logs, "\n")
        Siriguela_LogLabel.Parent.CanvasPosition = Vector2.new(0, Siriguela_LogLabel.AbsoluteSize.Y)
    end
end

local function randomString(len)
    len = len or 12
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local s = ""
    for _ = 1, len do
        local r = math.random(1, #chars)
        s = s .. chars:sub(r, r)
    end
    return s
end

