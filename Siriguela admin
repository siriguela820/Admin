reg("fly",{"fl"},"Toggle fly mode",function()
    Siriguela_FlyEnabled=not Siriguela_FlyEnabled; syncCharToggle("fly",Siriguela_FlyEnabled)
    notify("Fly",Siriguela_FlyEnabled and "Enabled" or "Disabled")
    if Siriguela_FlyEnabled then
        task.spawn(function()
            local char=getChar(); local root=getRoot(char); local human=getHuman(char)
            if not root or not human then Siriguela_FlyEnabled=false; syncCharToggle("fly",false); return end
            human.PlatformStand=true
            local bv=Instance.new("BodyVelocity"); bv.Velocity=Vector3.zero
            bv.MaxForce=Vector3.new(1e5,1e5,1e5); bv.Parent=root
            local bg=Instance.new("BodyGyro"); bg.MaxTorque=Vector3.new(1e5,1e5,1e5); bg.D=100; bg.Parent=root
            RunService.RenderStepped:Connect(function()
                if not Siriguela_FlyEnabled then bv:Destroy(); bg:Destroy(); human.PlatformStand=false; return end
                local cf=Camera.CFrame
                local fwd=(UserInputService:IsKeyDown(Enum.KeyCode.W) and cf.LookVector or Vector3.zero)
                    +(UserInputService:IsKeyDown(Enum.KeyCode.S) and -cf.LookVector or Vector3.zero)
                    +(UserInputService:IsKeyDown(Enum.KeyCode.A) and -cf.RightVector or Vector3.zero)
                    +(UserInputService:IsKeyDown(Enum.KeyCode.D) and cf.RightVector or Vector3.zero)
                    +(UserInputService:IsKeyDown(Enum.KeyCode.Space) and Vector3.yAxis or Vector3.zero)
                    +(UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and -Vector3.yAxis or Vector3.zero)
                bv.Velocity=fwd*Siriguela_FlySpeed; bg.CFrame=cf end)
        end)
    end
end)
